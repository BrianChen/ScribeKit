    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.0",
    "@types/node": "^25.9.1",
    "cheerio": "^1.2.0",
    "commander": "^13.1.0",
    "eslint": "^10.4.0",
    "langchain": "^1.4.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.4",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "dotenv": "^17.4.1",
    "tsup": "^8.4.0"
