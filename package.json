{
  "name": "scribekit",
  "version": "0.1.0",
  "description": "AI-powered multi-agent content generation toolkit",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "scribekit": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
